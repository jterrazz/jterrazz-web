{
    "name": "jterrazz-web",
    "version": "1.0.0",
    "description": "A personal portfolio website showcasing my development experiments, photography, and articles.",
    "author": "Jean-Baptiste Terrazzoni <contact@jterrazz.com>",
    "type": "module",
    "scripts": {
        "build": "next build",
        "start": "next start",
        "dev": "next dev",
        "test": "vitest --run",
        "test:unit": "vitest --run --project unit",
        "test:e2e": "next build && vitest --run --project e2e",
        "lint": "oxlint && oxfmt --check",
        "lint:fix": "oxlint --fix && oxfmt",
        "clean": "rm -rf .next && rm -rf node_modules",
        "sign:all": "tsx scripts/sign-all.ts",
        "sync": "rm -rf content/* && cp -r /Users/jterrazz/Documents/Studio/Articles/__LIBRARY__/Publications/@jterrazz/* content/"
    },
    "dependencies": {
        "@jterrazz/analytics": "^1.0.0",
        "@jterrazz/attestation": "^0.1.0",
        "@jterrazz/intelligence": "^6.0.0",
        "@jterrazz/reach": "^0.1.0",
        "@openpanel/nextjs": "^1.5.1",
        "@radix-ui/react-accordion": "^1.2.15",
        "@tabler/icons-react": "^3.44.0",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "clsx": "^2.1.1",
        "lucide-react": "^1.23.0",
        "motion": "^12.42.2",
        "next": "^16.2.10",
        "next-intl": "^4.13.1",
        "prism-react-renderer": "^2.4.1",
        "qr-code-styling": "^1.9.2",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-image-grid-gallery": "^4.0.1",
        "react-markdown": "^10.1.0",
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@jterrazz/test": "^9.2.1",
        "@jterrazz/typescript": "^6.1.0",
        "@tailwindcss/postcss": "^4.3.2",
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "playwright": "^1.49.0",
        "tsx": "^4.22.5",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": "24.x.x"
    }
}
